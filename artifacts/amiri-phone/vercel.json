{
  "buildCommand": "pnpm run build:prod",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://abncjqujfmnzucstuadu.supabase.co/functions/v1/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://abncjqujfmnzucstuadu.supabase.co/storage/v1/object/public/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
